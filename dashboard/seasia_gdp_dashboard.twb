      <aliases enabled='yes' />
      <column caption='GDP đầu người' datatype='real' datatype-customized='true' name='[Calculation_2169046185464442886]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='SUM([GDP (current US$)]) / SUM([Population, total])' />
      </column>
      <column caption='GDP 2024' datatype='real' default-format='n#,##0,,,B;-#,##0,,,B' name='[Calculation_2169046185466433543]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM( IF [Year] = 2024 THEN [GDP (current US$)] END )' />
      </column>
      <column caption='Tỉ lệ GDP VN' datatype='real' name='[Calculation_2169046185471803400]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_2169046185471950857] / [Calculation_2169046185466433543])*100' />
      </column>
      <column caption='GDP Việt Nam' datatype='real' name='[Calculation_2169046185471950857]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;    IF [REF_AREA_LABEL] = &quot;Viet Nam&quot;&#13;&#10;    AND [Year] = 2024&#13;&#10;    THEN [GDP (current US$)]&#13;&#10;END )' />
      </column>
      <column caption='Max Year' datatype='integer' name='[Calculation_2169046185474506762]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : MAX([Year]) }' />
      </column>
      <column caption='ASEAN GDP Prev Year' datatype='real' name='[Calculation_2169046185474646027]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED :&#13;&#10;    SUM(&#13;&#10;        IF [Year] = [Calculation_2169046185474506762] - 1 THEN [GDP (current US$)] END&#13;&#10;    )&#13;&#10;}' />
      </column>
      <column caption='ASEAN GDP Previous Year' datatype='real' name='[Calculation_2169046185474748428]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED :&#13;&#10;    SUM(&#13;&#10;        IF [Year] = [Calculation_2169046185474506762] THEN [GDP (current US$)] END&#13;&#10;    )&#13;&#10;}' />
      </column>
      <column caption='ASEAN YoY Growth' datatype='real' name='[Calculation_2169046185474940941]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(([Calculation_2169046185474748428] - [Calculation_2169046185474646027])&#13;&#10;/ [Calculation_2169046185474646027])*100' />
      </column>
      <column caption='GDP per capita' datatype='real' name='[Calculation_2169046185489207315]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[GDP (current US$)]/[Population, total]' />
      </column>
      <column caption='Rank' datatype='integer' hidden='true' name='[Calculation_2169046185491673109]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_UNIQUE(SUM([Calculation_2169046185489207315]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
